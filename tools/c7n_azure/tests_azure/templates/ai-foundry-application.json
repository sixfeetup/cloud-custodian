{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "uniqueId": {
            "type": "string"
        },
        "deploymentName": {
            "type": "string",
            "defaultValue": "cctest-gpt4o-mini"
        },
        "modelName": {
            "type": "string",
            "defaultValue": "gpt-4o-mini"
        },
        "modelVersion": {
            "type": "string",
            "defaultValue": "2024-07-18"
        },
        "projectName": {
            "type": "string",
            "defaultValue": "cctest-aifoundry-project"
        },
        "deployApplication": {
            "type": "bool",
            "defaultValue": true
        },
        "agentId": {
            "type": "string",
            "defaultValue": "00000000-0000-0000-0000-000000000001"
        },
        "agentName": {
            "type": "string",
            "defaultValue": "cctest-aifoundry-agent"
        }
    },
    "variables": {
        "accountName": "[concat('cctestaifoundry', parameters('uniqueId'))]",
        "projectName": "[parameters('projectName')]",
        "applicationName": "cctest-aifoundry-application"
    },
    "resources": [
        {
            "type": "Microsoft.CognitiveServices/accounts",
            "apiVersion": "2025-06-01",
            "name": "[variables('accountName')]",
            "location": "eastus",
            "kind": "AIServices",
            "identity": {
                "type": "SystemAssigned"
            },
            "sku": {
                "name": "S0"
            },
            "properties": {
                "allowProjectManagement": true,
                "customSubDomainName": "[variables('accountName')]",
                "publicNetworkAccess": "Enabled"
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.CognitiveServices/accounts/projects",
            "apiVersion": "2025-06-01",
            "name": "[format('{0}/{1}', variables('accountName'), variables('projectName'))]",
            "location": "eastus",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {},
            "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts', variables('accountName'))]"
            ]
        },
        {
            "type": "Microsoft.CognitiveServices/accounts/deployments",
            "apiVersion": "2025-06-01",
            "name": "[format('{0}/{1}', variables('accountName'), parameters('deploymentName'))]",
            "sku": {
                "name": "Standard",
                "capacity": 1
            },
            "properties": {
                "model": {
                    "format": "OpenAI",
                    "name": "[parameters('modelName')]",
                    "version": "[parameters('modelVersion')]"
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts', variables('accountName'))]"
            ]
        },
        {
            "type": "Microsoft.CognitiveServices/accounts/projects/applications",
            "apiVersion": "2025-10-01-preview",
            "name": "[format('{0}/{1}/{2}', variables('accountName'), variables('projectName'), variables('applicationName'))]",
            "condition": "[parameters('deployApplication')]",
            "properties": {
                "displayName": "[variables('applicationName')]",
                "description": "Cloud Custodian test AI Foundry application",
                "agents": [
                    {
                        "agentId": "[parameters('agentId')]",
                        "agentName": "[parameters('agentName')]"
                    }
                ],
                "tags": {
                    "environment": "test",
                    "owner": "cloud-custodian"
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('accountName'), variables('projectName'))]",
                "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('accountName'), parameters('deploymentName'))]"
            ]
        }
    ]
}
